# Sentinel AI — Environment Variables
# =====================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it with real keys.

# ── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...your-key-here...

# ── Database ───────────────────────────────────────────
# Absolute path to fundflow.db
# Download fundflow.db from the shared Google Drive link in SETUP.md
PS6_DB_PATH=e:\PS6\fundflow.db

# ── RAG Vector Store ───────────────────────────────────
# Either download from Google Drive (SETUP.md) OR run: python run_ps6.py --ingest
CHROMA_DB_PATH=e:\PS6\rag\vector_store

# ── Agent config ───────────────────────────────────────
AGENT_LLM_MODEL=gpt-4o-mini
AGENT_MAX_STEPS=10
AGENT_EVIDENCE_THRESHOLD=0.6

# ── API config ─────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
