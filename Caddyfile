# SENTINEL AI - Caddy reverse proxy (automatic free HTTPS)
#
# Replace <PUBLIC_IP> with your Oracle VM's RESERVED public IP, dots included.
# Example: if the IP is 152.67.10.20  ->  host line becomes  152.67.10.20.sslip.io
#
# sslip.io is a free public DNS service: <anything>.<IP>.sslip.io always resolves to <IP>.
# Caddy sees a real hostname, so it can get a real Let's Encrypt certificate automatically.
# No domain purchase, no DNS records to configure.

<PUBLIC_IP>.sslip.io {
    encode gzip
    reverse_proxy api:8000
}
