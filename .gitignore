# Sentinel AI — .gitignore
# ========================

# ── Secrets ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/
.virtualenv/

# ── Large data files (too big for GitHub — see SETUP.md) ─
fundflow.db
DataSet.csv
*.db
*.sqlite
*.sqlite3

# ── Derived/processed data (large, reproducible from source) ─
data/processed/
data/raw/

# ── RAG vector store (rebuild with --ingest) ─────────────
rag/vector_store/

# ── RAG corpus PDFs (too large for GitHub — download per SETUP.md) ─
# The 4 regulatory PDFs (FATF, RBI, FinCEN, MHA) must be placed manually.
# See SETUP.md Step 4b for download instructions.
rag/corpus/*.pdf

# ── Project Documents / Presentations (Do not track) ─────
*.pdf
*.pptx
PS6_IMPLEMENTATION_GUIDE_v2.txt
FUNDFLOW_TECHNICAL_REFERENCE.txt
DEMO_PRESENTATION_PLAYBOOK.md
DEMO_TEST_CASES.md
DEMO_GUIDE.txt
EXECUTION_PLAN_2_WEEKS.md

# ── Trained model binary (share via Google Drive) ────────
# models/saved/xgboost_fraud.pkl   ← uncomment to exclude model
# models/saved/model_metadata.json ← uncomment to exclude metadata

#tests
scratch_verify.py

# ── Generated test output ─────────────────────────────────
test_str_output.txt
verify_str_output.txt
*.log

# ── Jupyter / IPython ─────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE / OS ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Node / Frontend (if React frontend is in same repo) ───
node_modules/
.next/
dist/
.cache/
*.local
